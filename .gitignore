node_modules/
dist/
.env
.env.*
.DS_Store
.twf/

# Runtime UNVERIFIED skip ledger (verify-gate). Generated state, never committed;
# the merge gate reads it at land time. See docs/AGENT-HANDOFF.md.
.work/verify-ledger.jsonl

# Per-game agent scratch: contents are disposable and gitignored; only the
# contract README (the promotion rule) is committed. See games/_template/.work/.
games/*/.work/*
!games/*/.work/README.md
# Generated Capacitor native shells: cap-generated, never committed. Committed
# native inputs live in games/*/native-resources/. The structure linter enforces
# this — a tracked ios/ or android/ is a violation.
games/*/test-results/
games/*/ios/
games/*/android/

# Conductor scratch (ledgers, capture throwaways) — never tracked
.work/

# Local device registry: host-specific UDIDs, serials, and ssh aliases.
/devices.json
/tools/verify-device/devices.json

# Xcode result bundles (bulky binary; grid.html+panel.json are the committed evidence)
*.xcresult/

# Device capture video (hundreds of MB each; keep on disk, never in git —
# 7.4GB of these were purged from history on 2026-07-09)
docs/evidence/*/device-attachments/*.mp4

# Human-provided reference videos (large; keep local, never in git)
games/*/refs/video/*.mp4
games/*/refs/video/*.mov
