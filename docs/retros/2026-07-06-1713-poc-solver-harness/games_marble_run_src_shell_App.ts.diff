+      // ── DETERMINISTIC solver-bound auto-play (A*/search, never random) ─────
+      // Gameplay-to-terminal-state is bound to the in-game solver, not to any
+      // LLM/random policy: autoWin replays solveLevel().order; autoFail taps
+      // genuinely-blocked marbles. Both are the reliable capture drivers.
+      autoWin: async (stepMs = 260): Promise<boolean> => {
+        const level = this.controller.currentLevelDef();
+        if (!level) return false;
+        const plan = solveLevel(level);
+        if (!plan.solvable) return false;
+        for (const cell of plan.order) {
+          if (this.controller.engineRef()?.gameStatus() !== 'playing') break;
+          this.controller.tapCell(cell);
+          await new Promise((r) => setTimeout(r, stepMs));
+        }
+        return this.controller.engineRef()?.gameStatus() === 'won';
+      },
+      autoFail: async (stepMs = 260): Promise<boolean> => {
+        for (let i = 0; i < 100; i += 1) {
+          const engine = this.controller.engineRef();
+          if (!engine || engine.gameStatus() !== 'playing') break;
+          const movableIds = new Set(engine.movableMarbles().map((m) => m.id));
+          const blocked = engine.allMarbles().find((m) => !movableIds.has(m.id));
+          if (!blocked) break; // no blocked marble to burn a heart on
+          this.controller.tapCell(blocked.cell);
+          await new Promise((r) => setTimeout(r, stepMs));
+        }
+        return this.controller.engineRef()?.gameStatus() === 'failed';
+      },
