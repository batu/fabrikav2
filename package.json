{
  "name": "fabrikav2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "fabrika v2 monorepo: DOM shell + free canvas games. See docs/architecture/v2-architecture.md.",
  "workspaces": [
    "packages/*",
    "games/*",
    "tools/audit",
    "tools/create-game",
    "tools/refcap-compare",
    "tools/verify-device",
    "tools/verify-gate"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test:unit --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "verify-merge-gate": "node tools/verify-gate/merge-gate.mjs",
    "project-gate": "node tools/verify-gate/project-gate.mjs",
    "lint": "npm run lint --workspaces --if-present",
    "audit": "node tools/audit/src/cli.js",
    "knip": "knip",
    "create-game": "node tools/create-game/src/create-game.mjs",
    "refcap-compare": "node tools/refcap-compare/cli.mjs",
    "verify-device": "node tools/verify-device/cli.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "eslint": "^9.39.4",
    "happy-dom": "20.10.6",
    "knip": "6.24.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
