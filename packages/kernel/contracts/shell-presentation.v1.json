    { "id": "settings.sfx", "stateId": "settings", "bindingId": "settings.sfx", "actionHook": "settings-sfx", "minimumCount": 1, "instanceIds": ["settings.sfx"] },
    { "id": "settings.haptics", "stateId": "settings", "bindingId": "settings.haptics", "actionHook": "settings-haptics", "minimumCount": 1, "instanceIds": ["settings.haptics"] },
    { "id": "settings-back", "stateId": "settings", "bindingId": "flow.settings-back", "actionHook": "back", "minimumCount": 1, "instanceIds": ["settings.back"] },
    { "id": "resume", "stateId": "pause", "bindingId": "flow.resume", "actionHook": "pause-resume", "minimumCount": 1, "instanceIds": ["pause.resume"] },
    { "id": "pause.settings", "stateId": "pause", "bindingId": "flow.open-settings", "actionHook": "pause-settings", "minimumCount": 1, "instanceIds": ["pause.settings"] },
    { "id": "pause-home", "stateId": "pause", "bindingId": "flow.pause-home", "actionHook": "pause-quit", "minimumCount": 1, "instanceIds": ["pause.home"] },
    { "id": "win-next", "stateId": "win", "bindingId": "flow.next", "actionHook": "result-next", "minimumCount": 1, "instanceIds": ["win.next"] },
    { "id": "win-home", "stateId": "win", "bindingId": "flow.result-home", "actionHook": "result-menu", "minimumCount": 1, "instanceIds": ["win.home"] },
    { "id": "fail-retry", "stateId": "fail", "bindingId": "flow.retry", "actionHook": "result-retry", "minimumCount": 1, "instanceIds": ["fail.retry"] },
    { "id": "fail-home", "stateId": "fail", "bindingId": "flow.result-home", "actionHook": "result-menu", "minimumCount": 1, "instanceIds": ["fail.home"] }
  ],
  "editableAst": {
    "astVersion": 1,
    "numberBounds": {
      "offset": { "minimum": -1, "maximum": 1 },
      "normalizedSize": { "minimumExclusive": 0, "maximum": 1 },
      "order": { "minimum": 0, "maximum": 255, "integer": true },
      "opacity": { "minimum": 0, "maximum": 1 },
      "scale": { "minimum": 0.5, "maximum": 2 }
    },
    "enums": {
      "visibility": ["visible", "hidden"],
      "fit": ["contain", "cover"]
    },
    "colorFormats": ["#RRGGBB", "#RRGGBBAA"],
    "copy": { "maximumCodePoints": 512, "allowNewlines": true },
    "assetIds": { "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$", "mustExistInPublicationCatalog": true },
    "allowedPresentationFields": ["geometry", "order", "visibility", "copy", "colors", "assetId", "opacity", "scale"],
    "forbiddenFields": ["css", "html", "url", "href", "src", "style", "attribute", "attributes", "script", "handler", "onClick", "function", "expression", "source"]
  },
  "neutralIdPolicy": {
    "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$",
    "forbiddenTokens": ["blue", "green", "red", "gold", "kenney", "marble", "dog", "candy", "wood", "metal", "neon", "pixel", "cartoon"]
  },
  "publication": {
    "publicationIdAlgorithm": "sha256",
    "requiredStates": ["menu", "level", "settings", "pause", "win", "fail"],
    "canonicalComponentFields": [
      "id",
      "parentInstanceId",
      "order",
      "stateId",
      "roleId",
      "bindingId",
      "stateFamilyId",
      "actionId",
      "accessibility",
      "presentation",
      "variants"
    ],
    "portableContentNetworkPolicy": "disabled",
    "mixedRevisionPolicy": "reject"
  },
  "projection": {
    "pointerPath": "design/revision.json",
    "immutableRevisionRoot": "design/revisions",
    "revisionDirectoryName": "<projection-id>",
    "projectionIdAlgorithm": "sha256",
    "requiredArtifacts": ["tokens.css", "copy.ts", "assets.ts", "presentation.ts", "asset-identity.json"],
    "assetDirectory": "assets",
    "artifactHashAlgorithm": "sha256",
    "atomicPointerReplacement": true
  },
  "schemas": {
    "presentation": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "shell-presentation-v1/presentation",
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "contractVersion", "pages"],
      "properties": {
        "contractId": { "const": "shell-presentation-v1" },
        "contractVersion": { "const": "1.0.0" },
        "pages": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/page" }
        }
      },
      "$defs": {
        "number": { "type": "number", "minimum": -1, "maximum": 1 },
        "geometry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["offset", "size", "fit"],
          "properties": {
            "offset": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "y"],
              "properties": { "x": { "$ref": "#/$defs/number" }, "y": { "$ref": "#/$defs/number" } }
            },
            "size": {
              "type": "object",
              "additionalProperties": false,
              "required": ["width", "height"],
              "properties": {
                "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
              }
            },
            "fit": { "enum": ["contain", "cover"] }
          }
        },
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "geometry": { "$ref": "#/$defs/geometry" },
            "order": { "type": "integer", "minimum": 0, "maximum": 255 },
            "visibility": { "enum": ["visible", "hidden"] },
            "copy": { "type": "string", "maxLength": 512 },
            "colors": {
              "type": "object",
              "additionalProperties": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}(?:[0-9A-Fa-f]{2})?$" }
            },
            "assetId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
            "scale": { "type": "number", "minimum": 0.5, "maximum": 2 }
          }
        },
        "instance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "prototypeInstanceId",
            "parentInstanceId",
            "roleId",
            "bindingId",
            "stateFamilyId",
            "accessibility",
            "presentation",
            "variants"
          ],
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
            "prototypeInstanceId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
            "parentInstanceId": {
              "oneOf": [
                { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
                { "type": "null" }
              ]
            },
            "roleId": { "type": "string" },
            "bindingId": { "type": "string" },
            "stateFamilyId": { "type": "string" },
            "actionId": { "type": "string" },
            "accessibility": { "$ref": "#/$defs/accessibility" },
            "presentation": { "$ref": "#/$defs/visual" },
            "variants": { "type": "object", "additionalProperties": { "$ref": "#/$defs/visual" } }
          }
        },
        "accessibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["role", "nameKey", "stateSemantics", "traversalGroup"],
          "properties": {
            "role": { "type": "string", "minLength": 1 },
            "nameKey": { "type": "string", "minLength": 1 },
            "stateSemantics": {
              "type": "array",
              "uniqueItems": true,
              "items": { "enum": ["checked", "current", "disabled", "pressed", "selected"] }
            },
            "traversalGroup": { "type": "string", "minLength": 1 }
          }
        },
        "page": {
          "type": "object",
          "additionalProperties": false,
          "required": ["stateId", "editorPageId", "instances"],
          "properties": {
            "stateId": { "enum": ["menu", "level", "settings", "pause", "win", "fail"] },
            "editorPageId": { "type": "string" },
            "instances": { "type": "array", "items": { "$ref": "#/$defs/instance" } }
          }
        }
      }
    },
    "assetCatalog": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "shell-presentation-v1/asset-catalog",
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "contractVersion", "assets"],
      "properties": {
        "contractId": { "const": "shell-presentation-v1" },
        "contractVersion": { "const": "1.0.0" },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "slotId", "path", "mimeType", "width", "height", "hasAlpha", "sha256", "provenance"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
              "slotId": { "type": "string" },
              "path": { "type": "string", "pattern": "^assets/[a-z0-9][a-z0-9._/-]*\\.(?:png|jpe?g|webp)$" },
              "mimeType": { "enum": ["image/png", "image/jpeg", "image/webp"] },
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 },
              "hasAlpha": { "type": "boolean" },
              "sha256": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
              "provenance": {
                "type": "object",
                "additionalProperties": false,
                "required": ["sourceId", "sourceHash", "license"],
                "properties": {
                  "sourceId": { "type": "string", "minLength": 1 },
                  "sourceHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
                  "license": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    "publication": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "shell-presentation-v1/publication",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractId",
        "contractVersion",
        "publicationId",
        "projectJsonHash",
        "portableExportHash",
        "componentRecordsHash",
        "assetCatalogHash",
        "pageCount",
        "states"
      ],
      "properties": {
        "contractId": { "const": "shell-presentation-v1" },
        "contractVersion": { "const": "1.0.0" },
        "publicationId": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "projectJsonHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "portableExportHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "componentRecordsHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "assetCatalogHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "pageCount": { "const": 6 },
        "states": {
          "type": "array",
          "prefixItems": [
            { "const": "menu" },
            { "const": "level" },
            { "const": "settings" },
            { "const": "pause" },
            { "const": "win" },
            { "const": "fail" }
          ],
          "items": false
        }
      }
    },
    "projectionRevision": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "shell-presentation-v1/projection-revision",
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "contractVersion", "compatibilityHash", "projectionId", "sourcePublicationId", "revisionPath", "artifacts"],
      "properties": {
        "contractId": { "const": "shell-presentation-v1" },
        "contractVersion": { "const": "1.0.0" },
        "compatibilityHash": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "projectionId": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "sourcePublicationId": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "revisionPath": { "type": "string", "pattern": "^design/revisions/sha256-[a-f0-9]{64}$" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256", "bytes"],
            "properties": {
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
              "bytes": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "assetIdentity": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "$id": "shell-presentation-v1/asset-identity",
      "type": "object",
      "additionalProperties": false,
      "required": ["contractId", "contractVersion", "projectionId", "sourcePublicationId", "assets"],
      "properties": {
        "contractId": { "const": "shell-presentation-v1" },
        "contractVersion": { "const": "1.0.0" },
        "projectionId": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "sourcePublicationId": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["instanceId", "slotId", "assetId", "path", "sha256"],
            "properties": {
              "instanceId": { "type": "string" },
              "slotId": { "type": "string" },
              "assetId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
              "path": { "type": "string", "pattern": "^assets/[a-z0-9][a-z0-9._/-]*\\.(?:png|jpe?g|webp)$" },
              "sha256": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" }
            }
          }
        }
      }
    }
  }
}
