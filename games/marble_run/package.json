    "@fabrikav2/services": "*",
    "@fabrikav2/ui": "*",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@fabrikav2/testkit": "*",
    "@types/three": "^0.180.0"
  }
