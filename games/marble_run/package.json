    "authoring:phaser:reset": "node authoring/phaser-editor/tools.mjs reset"
  },
  "dependencies": {
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.2",
    "@fabrikav2/kernel": "*",
