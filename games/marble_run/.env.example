# Marble Run SDK component config. Every SDK is off unless its enable flag is
# true AND its required keys are present — "off" is a first-class Disabled state.
# Secrets (SDK keys, dev keys, tokens) live ONLY in the untracked .env; the ids
# that ship inside platform artifacts anyway (FB app id, AdMob app id) are
# platform-public but still flow through env for consistency.

# --- AppLovin MAX (active ad provider; AdMob is the config-switched fallback) ---
VITE_APPLOVIN_IOS_ENABLED=false
VITE_APPLOVIN_IOS_GENERAL_AUDIENCE_ONLY=false
VITE_APPLOVIN_IOS_SDK_KEY=__SET_IN_LOCAL_ENV__
VITE_APPLOVIN_IOS_BANNER_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
VITE_APPLOVIN_IOS_INTERSTITIAL_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
VITE_APPLOVIN_IOS_REWARDED_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
VITE_APPLOVIN_ANDROID_ENABLED=false
VITE_APPLOVIN_ANDROID_GENERAL_AUDIENCE_ONLY=false
VITE_APPLOVIN_ANDROID_SDK_KEY=__SET_IN_LOCAL_ENV__
VITE_APPLOVIN_ANDROID_BANNER_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
VITE_APPLOVIN_ANDROID_INTERSTITIAL_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
VITE_APPLOVIN_ANDROID_REWARDED_ID=__SET_WHEN_PUBLISHER_SUPPLIES__
# The publisher supplied ONE unit id of unknown format; partial mode lets MAX
# run with only the configured formats (others report not-configured).
VITE_APPLOVIN_ALLOW_PARTIAL_UNITS=true
# Marble Run must never block launch behind MAX's terms/privacy consent dialog.
VITE_APPLOVIN_CONSENT_FLOW_ENABLED=false
VITE_APPLOVIN_GDPR_TERMS_ALERT_ENABLED=false

# --- AppsFlyer attribution (selected over Adjust when configured) ---
VITE_APPSFLYER_ENABLED=false
VITE_APPSFLYER_DEV_KEY=__SET_IN_LOCAL_ENV__
VITE_APPSFLYER_APPLE_APP_ID=6793860059
VITE_APPSFLYER_DEBUG_LOGGING=false

# --- Facebook Core (app events only, no Login) ---
VITE_FB_ENABLED=false
VITE_FB_APP_ID=4138472436283342
VITE_FB_CLIENT_TOKEN=__SET_IN_LOCAL_ENV__
VITE_FB_AUTO_LOG_APP_EVENTS=false
VITE_FB_ADVERTISER_ID_COLLECTION=false

# --- Firebase Analytics (sink attaches only when all three are present;
# includePlugins also gates the native pod on this triple) ---
VITE_FIREBASE_API_KEY=__SET_IN_LOCAL_ENV__
VITE_FIREBASE_PROJECT_ID=__SET_IN_LOCAL_ENV__
VITE_FIREBASE_APP_ID=__SET_IN_LOCAL_ENV__

# --- Legal links (AppLovin consent flow requires the privacy URL; the SDK
# shows a debug error dialog without it) ---
VITE_PRIVACY_POLICY_URL=https://basegamelab.com/marble-run/privacy
VITE_TERMS_URL=https://basegamelab.com/marble-run/terms
