# Firebase Web API key; set only in an untracked local env file.
VITE_FIREBASE_API_KEY=__SET_IN_LOCAL_ENV__
# Firebase project identifier for the client SDK.
VITE_FIREBASE_PROJECT_ID=__SET_IN_LOCAL_ENV__
# Firebase Web app identifier for this game.
VITE_FIREBASE_APP_ID=__SET_IN_LOCAL_ENV__
# Firebase Auth domain for the client SDK.
VITE_FIREBASE_AUTH_DOMAIN=__SET_IN_LOCAL_ENV__
# Firebase Storage bucket name for the client SDK.
VITE_FIREBASE_STORAGE_BUCKET=__SET_IN_LOCAL_ENV__
# Firebase Cloud Messaging sender identifier.
VITE_FIREBASE_MESSAGING_SENDER_ID=__SET_IN_LOCAL_ENV__
# Firebase Analytics measurement identifier.
VITE_FIREBASE_MEASUREMENT_ID=__SET_IN_LOCAL_ENV__

# Disable remote configuration and use local defaults when true.
VITE_FTD_DISABLE_REMOTE_CONFIG=false

# Enable the iOS GameAnalytics client integration.
VITE_GAMEANALYTICS_IOS_ENABLED=false
# GameAnalytics iOS public game key; set locally when enabled.
VITE_GAMEANALYTICS_IOS_GAME_KEY=__SET_IN_LOCAL_ENV__
# GameAnalytics iOS client secret; set locally when enabled.
VITE_GAMEANALYTICS_IOS_SECRET_KEY=__SET_IN_LOCAL_ENV__
# Enable verbose GameAnalytics logging in non-production builds.
VITE_GAMEANALYTICS_VERBOSE_LOGGING=false

# RevenueCat iOS public SDK key; set only in an untracked local env file.
VITE_REVENUECAT_IOS_API_KEY=__SET_IN_LOCAL_ENV__
# RevenueCat Android public SDK key; set only in an untracked local env file.
VITE_REVENUECAT_ANDROID_API_KEY=__SET_IN_LOCAL_ENV__

# Enable Adjust attribution for the iOS client.
VITE_ADJUST_IOS_ENABLED=false
# Adjust iOS app token; set locally when Adjust is enabled.
VITE_ADJUST_IOS_APP_TOKEN=__SET_IN_LOCAL_ENV__
# Adjust iOS environment, either sandbox or production, set locally when enabled.
VITE_ADJUST_IOS_ENVIRONMENT=__SET_IN_LOCAL_ENV__
# Optional Adjust token for app-open events.
VITE_ADJUST_EVENT_APP_OPEN_TOKEN=__SET_IN_LOCAL_ENV__
# Optional Adjust token for level-start events.
VITE_ADJUST_EVENT_LEVEL_START_TOKEN=__SET_IN_LOCAL_ENV__
# Optional Adjust token for level-complete events.
VITE_ADJUST_EVENT_LEVEL_COMPLETE_TOKEN=__SET_IN_LOCAL_ENV__
# Optional Adjust token for level-fail events.
VITE_ADJUST_EVENT_LEVEL_FAIL_TOKEN=__SET_IN_LOCAL_ENV__
# Optional Adjust token for rewarded-ad-watched events.
VITE_ADJUST_EVENT_REWARDED_WATCHED_TOKEN=__SET_IN_LOCAL_ENV__
# Enable verbose Adjust logging in non-production builds.
VITE_ADJUST_VERBOSE_LOGGING=false

# Enable AppLovin MAX for the iOS client.
VITE_APPLOVIN_IOS_ENABLED=false
# AppLovin iOS SDK key; set locally when AppLovin is enabled.
VITE_APPLOVIN_IOS_SDK_KEY=__SET_IN_LOCAL_ENV__
# Confirm that the iOS build targets a general audience before enabling AppLovin.
VITE_APPLOVIN_IOS_GENERAL_AUDIENCE_ONLY=false
# Enable AppLovin MAX for the Android client.
VITE_APPLOVIN_ANDROID_ENABLED=false
# AppLovin Android SDK key; set locally when AppLovin is enabled.
VITE_APPLOVIN_ANDROID_SDK_KEY=__SET_IN_LOCAL_ENV__
# Confirm that the Android build targets a general audience before enabling AppLovin.
VITE_APPLOVIN_ANDROID_GENERAL_AUDIENCE_ONLY=false
# Record the current AppLovin user-consent state.
VITE_APPLOVIN_HAS_USER_CONSENT=false
# Record the current AppLovin do-not-sell state.
VITE_APPLOVIN_DO_NOT_SELL=true
# Enable the AppLovin consent flow.
VITE_APPLOVIN_CONSENT_FLOW_ENABLED=true
# Show the GDPR terms and privacy alert in AppLovin consent flow.
VITE_APPLOVIN_GDPR_TERMS_ALERT_ENABLED=true
# Enable verbose AppLovin logging in non-production builds.
VITE_APPLOVIN_VERBOSE_LOGGING=false

# AppLovin iOS banner placement identifier.
VITE_APPLOVIN_IOS_BANNER_ID=__SET_IN_LOCAL_ENV__
# AppLovin iOS interstitial placement identifier.
VITE_APPLOVIN_IOS_INTERSTITIAL_ID=__SET_IN_LOCAL_ENV__
# AppLovin iOS rewarded placement identifier.
VITE_APPLOVIN_IOS_REWARDED_ID=__SET_IN_LOCAL_ENV__
# AppLovin Android banner placement identifier.
VITE_APPLOVIN_ANDROID_BANNER_ID=__SET_IN_LOCAL_ENV__
# AppLovin Android interstitial placement identifier.
VITE_APPLOVIN_ANDROID_INTERSTITIAL_ID=__SET_IN_LOCAL_ENV__
# AppLovin Android rewarded placement identifier.
VITE_APPLOVIN_ANDROID_REWARDED_ID=__SET_IN_LOCAL_ENV__

# AdMob iOS banner unit identifier.
VITE_ADMOB_IOS_BANNER_ID=__SET_IN_LOCAL_ENV__
# AdMob iOS interstitial unit identifier.
VITE_ADMOB_IOS_INTERSTITIAL_ID=__SET_IN_LOCAL_ENV__
# AdMob iOS rewarded unit identifier.
VITE_ADMOB_IOS_REWARDED_ID=__SET_IN_LOCAL_ENV__
# AdMob Android banner unit identifier.
VITE_ADMOB_ANDROID_BANNER_ID=__SET_IN_LOCAL_ENV__
# AdMob Android interstitial unit identifier.
VITE_ADMOB_ANDROID_INTERSTITIAL_ID=__SET_IN_LOCAL_ENV__
# AdMob Android rewarded unit identifier.
VITE_ADMOB_ANDROID_REWARDED_ID=__SET_IN_LOCAL_ENV__

# Public privacy-policy URL shown by the game and consent flow.
VITE_FTD_PRIVACY_POLICY_URL=https://example.invalid/privacy
# Public terms-of-service URL shown by the game and consent flow.
VITE_FTD_TERMS_URL=https://example.invalid/terms
# Public data-deletion instructions URL shown by the game.
VITE_FTD_DATA_DELETION_URL=https://example.invalid/data-deletion
# Public support URL shown by the game.
VITE_FTD_SUPPORT_URL=https://example.invalid/support
# Public storefront link for this game.
VITE_FTD_STORE_LINK=https://example.invalid/store

# Enable remote CDN level loading; false retains bundled fallback behavior.
VITE_CDN_ENABLED=false
# Development CDN origin; the runtime has a bundled/default fallback.
VITE_CDN_ORIGIN_DEV=https://example.invalid/cdn-dev
# Production CDN origin; the runtime has a bundled/default fallback.
VITE_CDN_ORIGIN_PROD=https://example.invalid/cdn-prod
# Android-specific CDN origin; the runtime falls back to the production origin.
VITE_CDN_ORIGIN_ANDROID=https://example.invalid/cdn-android

# Public HTTPS endpoint for the optional owned analytics mirror.
VITE_FTD_OWNED_ANALYTICS_MIRROR_URL=https://example.invalid/analytics
# Public client credential for the optional owned analytics mirror.
VITE_FTD_OWNED_ANALYTICS_MIRROR_PUBLIC_CLIENT_KEY=__SET_IN_LOCAL_ENV__
