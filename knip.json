{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "**/ios/**",
    "**/android/**",
    "**/build/**",
    "**/dist/**",
    "**/.work/**",
    "docs/evidence/**",
    "**/test/fixtures/**"
  ],
  "workspaces": {
    "games/*": {
      "entry": [
        "src/main.ts",
        "game.config.ts",
        "capacitor.config.ts",
        "design/assets.ts",
        "design/copy.ts"
      ],
      "ignoreDependencies": [
        "@capacitor/ios"
      ]
    },
    "packages/sdk": {
      "ignoreDependencies": [
        "@capacitor/core",
        "@capacitor/haptics",
        "@capacitor-community/admob"
      ]
    }
  }
}
