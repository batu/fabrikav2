<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.appletolye.ftd-editor-rehearsal</string>
    <key>ProgramArguments</key>
    <array>
        <string>__PYTHON__</string>
        <string>__EDITOR_ROOT__/scripts/run_rehearsal.py</string>
        <string>--source-authoring</string>
        <string>__SOURCE_AUTHORING__</string>
        <string>--root</string>
        <string>__DATA_ROOT__</string>
        <string>--env-file</string>
        <string>__ENV_FILE__</string>
        <string>--port</string>
        <string>5192</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__EDITOR_ROOT__</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__DATA_ROOT__/logs/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__DATA_ROOT__/logs/stderr.log</string>
</dict>
</plist>
